# Local docker-compose environment for development on your machine.
# Copy to .env for local work. These values are intentionally safe demo defaults,
# not production secrets.

DOCKERHUB_USERNAME=local
IMAGE_TAG=demo

CORS_ORIGIN=http://localhost:7080,http://127.0.0.1:7080

NODE_GATEWAY_BIND_HOST=127.0.0.1
NODE_GATEWAY_PORT=7080

JWT_SECRET=dev-jwt-secret-local-only
JWT_EXPIRES_IN=1h

DEFAULT_USER_EMAIL=admin@example.com
DEFAULT_USER_PASSWORD=dev-password-local-only

DB_HOST=postgres
DB_PORT=5432
DB_USER=devops_app
DB_PASSWORD=devops-app-local-pass
DB_NAME=devops_demo

AUDIT_URL=http://audit-service:8084/audit/events
AUDIT_API_KEY=dev-audit-key-local
AUDIT_TIMEOUT_MS=2000

MAILER_URL=http://mailer-service:8083/send
MAILER_API_KEY=dev-mailer-key-local
MAILER_TIMEOUT_MS=5000

NOTIFY_URL=http://notification-service:8090/notify
NOTIFY_API_KEY=dev-notify-key-local
NOTIFY_TIMEOUT_MS=3000
NOTIFY_LOG_LEVEL=INFO

TWILIO_ACCOUNT_SID=local-twilio-sid
TWILIO_AUTH_TOKEN=local-twilio-token
TWILIO_FROM_NUMBER=+10000000000
TWILIO_TIMEOUT_MS=5000
TWILIO_STATUS_CALLBACK_URL=http://127.0.0.1:7080/notify/twilio/status

SMTP_HOST=mailpit
SMTP_PORT=1025
SMTP_USER=mailpit
SMTP_PASS=mailpit
SMTP_SECURE=false
SMTP_FROM=no-reply@local.test
